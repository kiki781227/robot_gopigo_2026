import cv2
import numpy as np
import threading
import time
from urllib.parse import urlparse, parse_qs
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

# ─── ÉTAT PARTAGÉ ─────────────────────────────────────────────────────────────
hsv_values = {
    'h_min': 100, 'h_max': 130,
    's_min': 100, 's_max': 255,
    'v_min':  50, 'v_max': 255,
}

# Stocke les 3 frames encodées en JPEG — prêtes à envoyer
frames = {
    'raw':    None,
    'mask':   None,
    'result': None,
}
frames_lock = threading.Lock()


# ─── BOUCLE CAMERA — UN SEUL THREAD ──────────────────────────────────────────
def camera_loop():
    cap = cv2.VideoCapture(0)
    if not cap.isOpened():
        print("Erreur : impossible d'ouvrir la camera")
        return

    print("Camera OK")

    while True:
        ret, frame = cap.read()
        if not ret:
            time.sleep(0.05)
            continue

        # Traitement HSV
        hsv    = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
        lower  = np.array([hsv_values['h_min'],
                           hsv_values['s_min'],
                           hsv_values['v_min']])
        upper  = np.array([hsv_values['h_max'],
                           hsv_values['s_max'],
                           hsv_values['v_max']])

        mask   = cv2.inRange(hsv, lower, upper)
        result = cv2.bitwise_and(frame, frame, mask=mask)

        # Texte sur la frame brute
        info = (f"H:[{hsv_values['h_min']}-{hsv_values['h_max']}] "
                f"S:[{hsv_values['s_min']}-{hsv_values['s_max']}] "
                f"V:[{hsv_values['v_min']}-{hsv_values['v_max']}]")
        cv2.putText(frame, info, (10, 30),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.55, (0, 255, 0), 2)

        # Encode les 3 images en JPEG une seule fois
        _, raw_jpg    = cv2.imencode('.jpg', frame,
                                     [cv2.IMWRITE_JPEG_QUALITY, 70])
        _, mask_jpg   = cv2.imencode('.jpg',
                                     cv2.cvtColor(mask, cv2.COLOR_GRAY2BGR),
                                     [cv2.IMWRITE_JPEG_QUALITY, 70])
        _, result_jpg = cv2.imencode('.jpg', result,
                                     [cv2.IMWRITE_JPEG_QUALITY, 70])

        # Met à jour les frames encodées
        with frames_lock:
            frames['raw']    = raw_jpg.tobytes()
            frames['mask']   = mask_jpg.tobytes()
            frames['result'] = result_jpg.tobytes()

        time.sleep(1 / 20)  # 20 fps

    cap.release()


# ─── GENERATEUR MJPEG ─────────────────────────────────────────────────────────
def mjpeg_generator(key, wfile):
    while True:
        with frames_lock:
            jpeg = frames[key]

        if jpeg is None:
            time.sleep(0.05)
            continue

        try:
            wfile.write(b'--frame\r\n')
            wfile.write(b'Content-Type: image/jpeg\r\n\r\n')
            wfile.write(jpeg)
            wfile.write(b'\r\n')
        except (BrokenPipeError, ConnectionResetError):
            break

        time.sleep(1 / 15)


# ─── HANDLER HTTP ─────────────────────────────────────────────────────────────
class Handler(BaseHTTPRequestHandler):

    def log_message(self, format, *args):
        pass

    def do_GET(self):
        parsed = urlparse(self.path)
        path   = parsed.path
        params = parse_qs(parsed.query)

        # Stream MJPEG
        if path in ('/stream/raw', '/stream/mask', '/stream/result'):
            key = path.split('/')[-1]
            self.send_response(200)
            self.send_header('Content-Type',
                             'multipart/x-mixed-replace; boundary=frame')
            self.end_headers()
            mjpeg_generator(key, self.wfile)

        # Mise à jour HSV
        elif path == '/set':
            for key in hsv_values:
                if key in params:
                    hsv_values[key] = int(params[key][0])
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(b'{"ok":true}')

        # Sauvegarde
        elif path == '/save':
            h_min = hsv_values['h_min']
            s_min = hsv_values['s_min']
            v_min = hsv_values['v_min']
            h_max = hsv_values['h_max']
            s_max = hsv_values['s_max']
            v_max = hsv_values['v_max']
            print(f"\n=== VALEURS A COPIER ===")
            print(f"np.array([{h_min}, {s_min}, {v_min}]),  # lower")
            print(f"np.array([{h_max}, {s_max}, {v_max}])   # upper")
            print(f"========================\n")
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(b'{"saved":true}')

        # Page HTML
        elif path == '/' or path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html; charset=utf-8')
            self.end_headers()
            self.wfile.write(HTML_PAGE.encode('utf-8'))

        else:
            self.send_response(404)
            self.end_headers()


# ─── PAGE HTML ────────────────────────────────────────────────────────────────
HTML_PAGE = """<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Calibration HSV</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: monospace; background: #1a1a2e; color: #eee; padding: 20px; }
    h1 { color: #4fc3f7; margin-bottom: 20px; font-size: 20px; }
    .streams { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .stream-box { text-align: center; }
    .stream-box p { margin-bottom: 6px; color: #aaa; font-size: 12px; }
    img.stream { width: 320px; height: 240px; border: 2px solid #333; border-radius: 6px; display: block; }
    .controls { background: #16213e; padding: 20px; border-radius: 8px; max-width: 500px; }
    .row { display: grid; grid-template-columns: 60px 1fr 40px; align-items: center; gap: 10px; margin-bottom: 12px; }
    label { color: #4fc3f7; font-size: 13px; }
    input[type=range] { width: 100%; accent-color: #4fc3f7; }
    .val { color: #fff; text-align: right; font-size: 13px; }
    .btns { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
    button { padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; font-family: monospace; font-weight: bold; font-size: 13px; }
    .b-bleu { background: #1565c0; color: #fff; }
    .b-vert { background: #2e7d32; color: #fff; }
    .b-save { background: #f57f17; color: #fff; }
    .output { margin-top: 16px; background: #0a0a0a; padding: 12px; border-radius: 4px; color: #69ff47; font-size: 12px; min-height: 50px; display: none; }
  </style>
</head>
<body>
  <h1>Calibration HSV — GoPiGo3</h1>

  <div class="streams">
    <div class="stream-box"><p>Camera brute</p><img class="stream" src="/stream/raw"></div>
    <div class="stream-box"><p>Masque</p><img class="stream" src="/stream/mask"></div>
    <div class="stream-box"><p>Resultat</p><img class="stream" src="/stream/result"></div>
  </div>

  <div class="controls">
    <div class="row"><label>H min</label><input type="range" id="h_min" min="0" max="179" value="100" oninput="upd('h_min',this.value)"><span class="val" id="d_h_min">100</span></div>
    <div class="row"><label>H max</label><input type="range" id="h_max" min="0" max="179" value="130" oninput="upd('h_max',this.value)"><span class="val" id="d_h_max">130</span></div>
    <div class="row"><label>S min</label><input type="range" id="s_min" min="0" max="255" value="100" oninput="upd('s_min',this.value)"><span class="val" id="d_s_min">100</span></div>
    <div class="row"><label>S max</label><input type="range" id="s_max" min="0" max="255" value="255" oninput="upd('s_max',this.value)"><span class="val" id="d_s_max">255</span></div>
    <div class="row"><label>V min</label><input type="range" id="v_min" min="0" max="255" value="50"  oninput="upd('v_min',this.value)"><span class="val" id="d_v_min">50</span></div>
    <div class="row"><label>V max</label><input type="range" id="v_max" min="0" max="255" value="255" oninput="upd('v_max',this.value)"><span class="val" id="d_v_max">255</span></div>

    <div class="btns">
      <button class="b-bleu" onclick="preset('bleu')">Bleu</button>
      <button class="b-vert" onclick="preset('vert')">Vert</button>
      <button class="b-save" onclick="save()">Sauvegarder</button>
    </div>
    <div class="output" id="out"></div>
  </div>

  <script>
    const presets = {
      bleu: {h_min:100,h_max:130,s_min:100,s_max:255,v_min:50,v_max:255},
      vert: {h_min:40, h_max:80, s_min:60, s_max:255,v_min:50,v_max:255}
    };

    function upd(k, v) {
      document.getElementById('d_' + k).textContent = v;
      fetch('/set?' + k + '=' + v);
    }

    function setSlider(k, v) {
      document.getElementById(k).value = v;
      document.getElementById('d_' + k).textContent = v;
      fetch('/set?' + k + '=' + v);
    }

    function preset(name) {
      Object.entries(presets[name]).forEach(([k,v]) => setSlider(k,v));
    }

    function save() {
      fetch('/save');
      const vals = ['h_min','h_max','s_min','s_max','v_min','v_max']
        .map(k => document.getElementById(k).value);
      const out = document.getElementById('out');
      out.style.display = 'block';
      out.innerHTML =
        'np.array([' + vals[0] + ', ' + vals[2] + ', ' + vals[4] + ']),  # lower<br>' +
        'np.array([' + vals[1] + ', ' + vals[3] + ', ' + vals[5] + '])   # upper';
    }
  </script>
</body>
</html>
"""

# ─── MAIN ─────────────────────────────────────────────────────────────────────
if __name__ == '__main__':
    print("Demarrage camera...")
    t = threading.Thread(target=camera_loop, daemon=True)
    t.start()

    # Attend que la première frame soit prête
    print("Attente premiere frame...")
    while frames['raw'] is None:
        time.sleep(0.1)
    print("Premiere frame OK !")

    port = 8080
    server = HTTPServer(('0.0.0.0', port), Handler)
    print(f"Serveur demarre -> http://TON_IP_PI:{port}")
    print("Ctrl+C pour arreter")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nArret")
